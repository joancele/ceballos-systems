---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/organisms/Footer/Footer.astro';
import './demostracion.css';
---

<Layout title="TFM Recursos | Desglose de Calificación">
  <div class="site-wrapper">
    <header class="subhub-header">
      <div class="header-container">
        <a href="/recursos" class="back-link mono">
          <span class="arrow">←</span> Volver a Recursos
        </a>
        <div class="breadcrumbs mono">
          <span>Recursos</span> / <span>SA8</span> / <span>Calificación</span> / <span class="active">Demostración</span>
        </div>
      </div>
    </header>

    <main class="main-content">
      <article class="resource-article">
        <div class="article-header">
          <div class="tag-badge mono dot-white">
            <span class="dot"></span> PERFIL DE CALIFICACIÓN
          </div>
          <h1 class="article-title">Expediente de Calificación: Lucas</h1>
          <p class="article-lead">
            Triangulación de notas y desglose de ponderaciones para el alumno Lucas con el rol de <strong>Constructor</strong>.
          </p>
        </div>

        <!-- Student Profile Meta -->
        <section class="content-section">
          <div class="profile-card glass">
            <div class="profile-avatar mono">[LUCAS_CONSTRUCTOR]</div>
            <div class="profile-meta-details">
              <span class="mono">GRUPO: Ares-3</span>
              <span class="mono">ROL ESPECIALISTA: Mecanizado y Construcción (PRL)</span>
              <span class="mono">SITUACIÓN DE APRENDIZAJE: SA8 - Biodomo Inteligente</span>
            </div>
          </div>
        </section>

        <!-- Grade Breakdown Table -->
        <section class="content-section">
          <h2 class="section-title">Desglose de Instrumentos de la SA</h2>
          <div class="table-container">
            <table class="grades-table">
              <thead>
                <tr>
                  <th class="col-act">Actividad</th>
                  <th class="col-instrument">Instrumento de Evaluación</th>
                  <th class="col-grade">Calificación (0-10)</th>
                  <th class="col-weight">Peso (%)</th>
                  <th class="col-contrib">Aportación a la Nota Final</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="mono">A1</td>
                  <td>Rúbrica de reflexión ecosocial (Dossier y debate)</td>
                  <td class="num">7,00</td>
                  <td class="num">10%</td>
                  <td class="num font-bold">0,70</td>
                </tr>
                <tr>
                  <td class="mono">A2</td>
                  <td>Rúbrica del informe gráfico individual (Su rol)</td>
                  <td class="num">8,00</td>
                  <td class="num">15%</td>
                  <td class="num font-bold">1,20</td>
                </tr>
                <tr>
                  <td class="mono">A3</td>
                  <td>Rúbrica técnica del prototipo (Biodomo final)</td>
                  <td class="num">9,25</td>
                  <td class="num">25%</td>
                  <td class="num font-bold">2,31</td>
                </tr>
                <tr>
                  <td class="mono">A3</td>
                  <td>Lista de cotejo actitudinal diaria (Taller y PRL)</td>
                  <td class="num">10,00</td>
                  <td class="num">5%</td>
                  <td class="num font-bold">0,50</td>
                </tr>
                <tr>
                  <td class="mono">A4</td>
                  <td>Rúbrica del Pitch (Valoración del Docente)</td>
                  <td class="num">8,00</td>
                  <td class="num">7,5%</td>
                  <td class="num font-bold">0,60</td>
                </tr>
                <tr>
                  <td class="mono">A4</td>
                  <td>Diana de coevaluación del Pitch (Compañeros)</td>
                  <td class="num">7,00</td>
                  <td class="num">7,5%</td>
                  <td class="num font-bold">0,53</td>
                </tr>
                <tr>
                  <td class="mono">A5</td>
                  <td>Métricas del software adaptativo (Teoría individual)</td>
                  <td class="num">5,50</td>
                  <td class="num">20%</td>
                  <td class="num font-bold">1,10</td>
                </tr>
                <tr>
                  <td class="mono">A5</td>
                  <td>Diana de coevaluación cruzada (Auditoría externa)</td>
                  <td class="num">7,00</td>
                  <td class="num">5%</td>
                  <td class="num font-bold">0,35</td>
                </tr>
                <tr>
                  <td class="mono">A5</td>
                  <td>Cuestionario de metacognición (Autoevaluación)</td>
                  <td class="num">9,00</td>
                  <td class="num">5%</td>
                  <td class="num font-bold">0,45</td>
                </tr>
                <tr class="total-row">
                  <td colspan="2" class="total-label">EVALUACIÓN COMPLETA DE LA SA (TOTAL)</td>
                  <td class="num">-</td>
                  <td class="num">100%</td>
                  <td class="num highlight-total">7,74</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Final Verdict Panel -->
        <section class="content-section">
          <div class="verdict-card border-accent highlight-panel mono">
            <div class="verdict-header">
              <span>[CALIFICACIÓN_FINAL_DE_LA_SA]</span>
              <span class="verdict-score">7,74</span>
            </div>
            <div class="verdict-body">
              <p>NOTA FINAL TRIANGULADA: <strong>7,74 - NOTABLE</strong></p>
              <p>
                <strong>Observaciones de Evaluación:</strong> Lucas destaca de forma sobresaliente en el chasis físico y en el cumplimiento de normas de prevención de riesgos (10/10 en cotejo actitudinal), lo que pondera de forma prioritaria en su rol de Constructor. Sus aportaciones cooperativas compensan las partes de teoría de software generales, logrando una calificación sólida y justa en la Situación de Aprendizaje.
              </p>
            </div>
          </div>
        </section>
      </article>
    </main>

    <Footer />
  </div>
</Layout>
