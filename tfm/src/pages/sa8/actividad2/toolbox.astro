---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/organisms/Footer/Footer.astro';
import ToolboxDashboard from '../../../components/organisms/ToolboxDashboard/ToolboxDashboard.astro';
import './toolbox.css';
---

<Layout title="TFM Recursos | Panel de Especialización (Actividad 2)">
  <header class="subhub-header">
    <div class="header-container">
      <a href="/recursos" class="back-link mono">
        <span class="arrow">←</span> Volver a Recursos
      </a>
      <div class="breadcrumbs mono">
        <span>Recursos</span> / <span>SA8</span> / <span>Actividad 2</span> / <span class="active">Toolbox</span>
      </div>
    </div>
  </header>

  <main class="main-content">
    <article class="resource-article">
      <div class="article-header">
        <div class="tag-badge mono dot-purple">
          <span class="dot"></span> • APRENDIZAJE COOPERATIVO (TÉCNICA JIGSAW)
        </div>
        <h1 class="article-title">Centro de Mando: Academias de Especialización</h1>
        <p class="article-lead">
          Accede a tu terminal individual de especialización. Resuelve el minireto de tu subsistema, consolida el andamiaje técnico y certifica tu competencia experta para el ensamblaje final del Biodomo.
        </p>
      </div>

      <ToolboxDashboard />
    </article>
  </main>

  <Footer />
</Layout>

