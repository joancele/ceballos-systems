---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/molecules/ThemeToggle/ThemeToggle.astro';
import Footer from '../components/organisms/Footer/Footer.astro';
import './index.css';

const hubUrl = import.meta.env.PUBLIC_HUB_URL || 'https://joseceballos.link';
---

<Layout title="CEBALLOS_SYSTEMS | Proyecto TFM">
  <div class="site-wrapper">
    <!-- Sub-Hub Custom Header -->
    <header class="subhub-header">
      <div class="header-container">
        <a href={hubUrl} class="back-link mono">
          <span class="arrow">←</span> Volver al Hub
        </a>
        
        <div class="breadcrumbs mono">
          <span>Inicio</span> / <span class="active">TFM</span>
        </div>
        
        <div class="toggle-container">
          <ThemeToggle />
        </div>
      </div>
    </header>
    
    <main class="main-content">
      <!-- Title Section -->
      <section class="title-section">
        <div class="project-badge mono">[PROYECTO_TFM]</div>
        <h1 class="page-title">
          El Invernadero Automatizado
        </h1>
        <p class="page-subtitle">
          Diseño e implementación de un Biodomo Inteligente enmarcado en la narrativa gamificada "Misión a Marte" para Tecnología y Digitalización.
        </p>
      </section>
      
      <!-- Core Info Panel -->
      <div class="grid-layout">
        <!-- Presentation Column -->
        <div class="info-column">
          <section class="text-section card glass">
            <h2 class="section-heading mono">// PRESENTACIÓN DEL PROYECTO</h2>
            <p>
              Este proyecto de Trabajo Fin de Máster (TFM) propone una arquitectura pedagógica completa para la materia de Tecnología y Digitalización en Educación Secundaria. A través del diseño y construcción cooperativa de un invernadero automatizado con Arduino, los alumnos adquieren habilidades clave en pensamiento computacional, electrónica analógica y cultura maker.
            </p>
            <p>
              La unidad está contextualizada bajo la narrativa inmersiva <strong>"Misión a Marte"</strong>, donde cada tripulación tiene la responsabilidad de programar y construir los sistemas de soporte vital hídrico de su propia base espacial (Base Ares-V), estableciendo puentes de transferencia de conocimiento constantes con problemáticas del mundo real (Doñana).
            </p>
          </section>

          <section class="text-section card glass">
            <h2 class="section-heading mono">// PILARES METODOLÓGICOS</h2>
            <ul class="pillars-list">
              <li>
                <strong>Cultura del Error:</strong> Desestigmatización del fallo técnico a través de dinámicas de depuración dirigida (debugging). Los bugs no son fracasos; son hitos de aprendizaje.
              </li>
              <li>
                <strong>Coeducación Líquida:</strong> Erradicación de los sesgos de género mediante cartas de rol líquidas (Diseño, Programación, Construcción) que rotan periódicamente.
              </li>
              <li>
                <strong>Evaluación Disociada:</strong> Separación metodológica del esfuerzo/procesos frente a la precisión puramente técnica para garantizar una evaluación inclusiva (DUA).
              </li>
            </ul>
          </section>
        </div>

        <!-- CTA & Repository Column -->
        <div class="cta-column">
          <div class="cta-card border-accent highlight-panel">
            <span class="cta-badge mono">[ACCESO_REPOSITORIO]</span>
            <h2 class="cta-card-title">Recursos Didácticos</h2>
            <p class="cta-card-desc">
              Accede al repositorio completo de recursos y prototipos interactivos diseñados para la defensa y despliegue del proyecto.
            </p>
            
            <div class="card-bullets mono">
              <span>-> Portal de la Academia (Jigsaw)</span>
              <span>-> App de Test (Repetición Espaciada)</span>
              <span>-> Rúbricas y Dianas del Proyecto</span>
              <span>-> Cuadro de Mando de Calificación</span>
            </div>

            <a href="/recursos" class="btn btn-outline cta-btn">
              Explorar Recursos
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>
