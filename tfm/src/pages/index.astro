---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/molecules/ThemeToggle/ThemeToggle.astro';
import Footer from '../components/organisms/Footer/Footer.astro';

const hubUrl = import.meta.env.PUBLIC_HUB_URL || 'https://joseceballos.link';
---

<Layout title="CEBALLOS_SYSTEMS | Proyecto TFM">
  <div class="site-wrapper">
    <!-- Sub-Hub Custom Header -->
    <header class="subhub-header">
      <div class="header-container">
        <a href={hubUrl} class="back-link mono">
          <span class="arrow">←</span> Volver al Hub
        </a>
        
        <div class="breadcrumbs mono">
          <span>Inicio</span> / <span class="active">TFM</span>
        </div>
        
        <div class="toggle-container">
          <ThemeToggle />
        </div>
      </div>
    </header>
    
    <main class="main-content">
      <!-- Title Section -->
      <section class="title-section">
        <div class="project-badge mono">[PROYECTO_TFM]</div>
        <h1 class="page-title">
          El Invernadero Automatizado
        </h1>
        <p class="page-subtitle">
          Diseño e implementación de un Biodomo Inteligente enmarcado en la narrativa gamificada "Misión a Marte" para Tecnología y Digitalización.
        </p>
      </section>
      
      <!-- Core Info Panel -->
      <div class="grid-layout">
        <!-- Presentation Column -->
        <div class="info-column">
          <section class="text-section card glass">
            <h2 class="section-heading mono">// PRESENTACIÓN DEL PROYECTO</h2>
            <p>
              Este proyecto de Trabajo Fin de Máster (TFM) propone una arquitectura pedagógica completa para la materia de Tecnología y Digitalización en Educación Secundaria. A través del diseño y construcción cooperativa de un invernadero automatizado con Arduino, los alumnos adquieren habilidades clave en pensamiento computacional, electrónica analógica y cultura maker.
            </p>
            <p>
              La unidad está contextualizada bajo la narrativa inmersiva <strong>"Misión a Marte"</strong>, donde cada tripulación tiene la responsabilidad de programar y construir los sistemas de soporte vital hídrico de su propia base espacial (Base Ares-V), estableciendo puentes de transferencia de conocimiento constantes con problemáticas del mundo real (Doñana).
            </p>
          </section>

          <section class="text-section card glass">
            <h2 class="section-heading mono">// PILARES METODOLÓGICOS</h2>
            <ul class="pillars-list">
              <li>
                <strong>Cultura del Error:</strong> Desestigmatización del fallo técnico a través de dinámicas de depuración dirigida (debugging). Los bugs no son fracasos; son hitos de aprendizaje.
              </li>
              <li>
                <strong>Coeducación Líquida:</strong> Erradicación de los sesgos de género mediante cartas de rol líquidas (Diseño, Programación, Construcción) que rotan periódicamente.
              </li>
              <li>
                <strong>Evaluación Disociada:</strong> Separación metodológica del esfuerzo/procesos frente a la precisión puramente técnica para garantizar una evaluación inclusiva (DUA).
              </li>
            </ul>
          </section>
        </div>

        <!-- CTA & Repository Column -->
        <div class="cta-column">
          <div class="cta-card border-accent highlight-panel">
            <span class="cta-badge mono">[ACCESO_REPOSITORIO]</span>
            <h2 class="cta-card-title">Recursos Didácticos</h2>
            <p class="cta-card-desc">
              Accede al repositorio completo de recursos y prototipos interactivos diseñados para la defensa y despliegue del proyecto.
            </p>
            
            <div class="card-bullets mono">
              <span>-> Portal de la Academia (Jigsaw)</span>
              <span>-> App de Test (Repetición Espaciada)</span>
              <span>-> Rúbricas y Dianas del Proyecto</span>
              <span>-> Cuadro de Mando de Calificación</span>
            </div>

            <a href="/recursos" class="btn btn-outline cta-btn">
              Explorar Recursos
              <span class="btn-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .site-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  
  /* Sub-Hub Header */
  .subhub-header {
    border-bottom: 1px solid hsl(var(--border-color));
    padding: 1.5rem 0;
    width: 100%;
  }
  
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .back-link {
    font-size: 0.8rem;
    font-weight: 700;
    color: hsl(var(--text-secondary));
    text-decoration: none;
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .back-link:hover {
    color: hsl(var(--accent-primary));
  }
  
  .back-link .arrow {
    transition: transform 0.2s ease;
  }
  
  .back-link:hover .arrow {
    transform: translateX(-3px);
  }
  
  .breadcrumbs {
    font-size: 0.75rem;
    color: hsl(var(--text-muted));
  }
  
  .breadcrumbs .active {
    color: hsl(var(--text-primary));
    font-weight: 700;
  }
  
  .toggle-container {
    display: flex;
    align-items: center;
  }
  
  /* Main Content */
  .main-content {
    flex-grow: 1;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 3.5rem 2rem 5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  
  .title-section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }
  
  .project-badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: hsl(var(--accent-primary));
    border: 1px solid rgba(0, 255, 65, 0.3);
    background-color: rgba(0, 255, 65, 0.03);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
  }
  
  .page-title {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: hsl(var(--text-primary));
    line-height: 1.1;
  }
  
  .page-subtitle {
    font-size: 1.25rem;
    line-height: 1.5;
    color: hsl(var(--text-secondary));
    max-width: 900px;
  }

  /* Grid Layout */
  .grid-layout {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
  }

  .info-column {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .card {
    padding: 2.5rem;
    border-radius: 2px;
  }

  .text-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    line-height: 1.6;
    font-size: 1rem;
    color: hsl(var(--text-secondary));
  }

  .text-section p strong {
    color: hsl(var(--text-primary));
  }

  .section-heading {
    font-size: 0.85rem;
    color: hsl(var(--text-muted));
    letter-spacing: 0.05em;
    border-bottom: 1px solid hsl(var(--border-color));
    padding-bottom: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .pillars-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .pillars-list li {
    position: relative;
    padding-left: 1.5rem;
  }

  .pillars-list li::before {
    content: "::";
    position: absolute;
    left: 0;
    color: hsl(var(--accent-primary));
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  /* CTA Panel Styles */
  .cta-column {
    display: flex;
    flex-direction: column;
  }

  .cta-card {
    background-color: hsl(var(--bg-secondary));
    border-radius: 2px;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;
    justify-content: center;
  }

  .highlight-panel {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.005) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.005) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .border-accent {
    border: 1px solid hsl(var(--border-color));
  }

  .cta-badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: hsl(var(--accent-primary));
  }

  .cta-card-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: hsl(var(--text-primary));
  }

  .cta-card-desc {
    font-size: 0.95rem;
    line-height: 1.5;
    color: hsl(var(--text-secondary));
  }

  .card-bullets {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: hsl(var(--text-muted));
    border-top: 1px dashed hsl(var(--border-color));
    border-bottom: 1px dashed hsl(var(--border-color));
    padding: 1rem 0;
  }

  .cta-btn {
    align-self: flex-start;
    padding: 0.85rem 1.75rem;
  }

  .btn-arrow {
    margin-left: 0.5rem;
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .cta-btn:hover .btn-arrow {
    transform: translateX(4px);
  }
  
  @media (max-width: 992px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2.5rem;
    }
    .cta-card {
      padding: 2rem;
    }
  }
</style>
