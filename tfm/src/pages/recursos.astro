---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/molecules/ThemeToggle/ThemeToggle.astro';
import HubGrid from '../components/organisms/HubGrid/HubGrid.astro';
import './recursos.css';

const tfmCards = [
  {
    title: 'Portal de la Academia (Guías de Especialización)',
    description: 'Acceso a los dossiers de especialización técnica individualizados por roles: Modelado CAD (Tinkercad), Algorítmica y Depuración (ArduinoBlocks), y Mecanizado Seguro (PRL en el Aula-Taller) para la resolución de los miniretos autónomos de la técnica Jigsaw.',
    index: '01',
    href: '/sa8/actividad2/toolbox',
    actionText: 'Ver Especialidades',
    dotTag: { text: 'APRENDIZAJE COOPERATIVO', colorClass: 'dot-purple' }
  },
  {
    title: 'App de Test: Repetición Espaciada',
    description: 'Prototipo funcional de la aplicación interactiva para la consolidación de los saberes teóricos y conceptuales. El algoritmo personaliza el feedback inmediato desestigmatizando el error y automatiza la recuperación según la curva de olvido del estudiante.',
    index: '02',
    href: '/spaced-repetition-app/demostracion',
    actionText: 'Probar Aplicación',
    dotTag: { text: 'INSTRUCCIÓN ADAPTATIVA', colorClass: 'dot-green' }
  },
  {
    title: 'Matrices y Dianas de Evaluación',
    description: 'Desglose multinivel de la rúbrica técnica del prototipo (Biodomo) con doble ponderación por corresponsabilidad de rol, dianas digitales para la coevaluación del Pitch en tiempo real y listas de cotejo para el desempeño actitudinal diario.',
    index: '03',
    href: '/sa8/actividad3/rubrica_prototipo',
    actionText: 'Explorar Instrumentos',
    dotTag: { text: 'EVALUACIÓN AUTÉNTICA', colorClass: 'dot-yellow' }
  },
  {
    title: 'Cuadro de Mando de Calificación',
    description: 'Cuadro de registro automatizado para la triangulación operativa de datos de la SA. Integra las ponderaciones competenciales normativas del currículo de Andalucía y aplica de forma matemática el algoritmo de la evaluación disociada.',
    index: '04',
    href: '/sa8/calificacion/demostracion',
    actionText: 'Abrir Cuadro de Mando',
    dotTag: { text: 'ANALÍTICA DE APRENDIZAJE', colorClass: 'dot-white' }
  }
];

const hubUrl = import.meta.env.PUBLIC_HUB_URL || 'https://joseceballos.link';
---

<Layout title="CEBALLOS_SYSTEMS | Recursos TFM">
  <div class="site-wrapper">
    <!-- Sub-Hub Custom Header -->
    <header class="subhub-header">
      <div class="header-container">
        <a href="/" class="back-link mono">
          <span class="arrow">←</span> Volver al TFM
        </a>
        
        <div class="breadcrumbs mono">
          <span>TFM</span> / <span class="active">Recursos</span>
        </div>
        
        <div class="toggle-container">
          <ThemeToggle />
        </div>
      </div>
    </header>
    
    <main class="main-content">
      <!-- Title Section -->
      <section class="title-section">
        <h1 class="page-title">
          Ecosistema de Recursos Didácticos de la SA
        </h1>
        <p class="page-subtitle">
          Repositorio técnico y pedagógico de materiales interactivos, instrumentos de evaluación auténtica y analíticas de aprendizaje diseñadas para la <strong>SA8 — El Invernadero Automatizado</strong>, situación de aprendizaje del proyecto <em>Protocolo Marte: La Colonia Autosostenible</em> (Tecnología y Digitalización, 3.º ESO).
        </p>
      </section>
      
      <!-- Grid of TFM cards -->
      <HubGrid cards={tfmCards} />
    </main>
    
    <!-- Footer in Swiss Monolith style -->
    <footer class="main-footer">
      <div class="footer-container">
        <div class="footer-left">
          <span class="brand mono">Systems Educator</span>
          <p class="copyright mono">&copy; 2024 Systems Educator. Built with architectural precision.</p>
        </div>
        <div class="footer-links mono">
          <a href="#privacy" class="footer-link">Privacy</a>
          <a href="#terms" class="footer-link">Terms</a>
          <a href="#archive" class="footer-link">Archive &#123;GH&#125;[IN]</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>
