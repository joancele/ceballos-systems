---
import './HardwareBlock.css';
---

<section class="academy-section glass border-develop locked-section" id="dev-block-hardware">
  <!-- Lock Overlay -->
  <div class="lock-overlay" id="hardware-lock-overlay">
    <span class="lock-icon">🔒</span>
    <p class="lock-text">Módulo Bloqueado. Supera la Miniprueba del Bloque 1 (Software) para desbloquear las fichas de conexiones.</p>
  </div>

  <div class="section-badge mono text-develop">🟧 BLOQUE 2: Fichas Técnicas y Conexiones (Hardware)</div>
  <h2 class="section-title">Manual de Supervivencia: Sensores y Actuadores</h2>
  
  <p class="section-intro-desc" style="font-size: 0.9rem; color: hsl(var(--text-secondary)); margin: 0;">Explora la guía visual de conexionado de cada componente de la misión seleccionando una pestaña a continuación:</p>

  <!-- Tabs control -->
  <div class="hardware-tabs">
    <button class="hw-tab-btn active-hw-tab" data-hw="dht22">🌡️ Temp. y Humedad (DHT22)</button>
    <button class="hw-tab-btn" data-hw="humedad">💧 Humedad del Suelo</button>
    <button class="hw-tab-btn" data-hw="ldr">☀️ Sensor de Luz LDR</button>
    <button class="hw-tab-btn" data-hw="bomba">⚙️ Minibomba & Relé</button>
    <button class="hw-tab-btn" data-hw="led">💡 Iluminación LED</button>
  </div>

  <!-- Tab content -->
  <div class="hardware-tab-content glass">
    <!-- Tab DHT22 -->
    <div class="hw-tab-pane" id="hw-pane-dht22">
      <div class="hw-pane-header">
        <h4>🌡️ Ficha: Sensor de Temperatura y Humedad (DHT22)</h4>
      </div>
      
      <!-- DHT22 Interactive Infographic Container -->
      <div class="dht22-infographic-container">
        <!-- Left Column -->
        <div class="dht22-left-column">
          <!-- Panel 1: INTERNAL SENSING -->
          <div class="dht22-panel glass" data-panel-detail="internal">
            <div class="dht22-panel-header">
              <span class="dht22-panel-badge mono">01 / DETECTOR</span>
              <h5>INTERNAL SENSING</h5>
            </div>
            <div class="dht22-panel-body">
              <p>Diseño interior de detección dual de alta precisión:</p>
              <div class="sensing-elements">
                <div class="sensing-item">
                  <svg class="icon-svg" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2m0 2a8 8 0 0 1 8 8c0 1.25-.3 2.43-.8 3.5H4.8c-.5-1.07-.8-2.25-.8-3.5a8 8 0 0 1 8-8m-6 9.5h12c-.2 1.3-.8 2.5-1.7 3.4L12 12.8L7.7 16.9c-.9-.9-1.5-2.1-1.7-3.4Z"/></svg>
                  <span>Polímero Capacitivo (Humedad)</span>
                </div>
                <div class="sensing-item">
                  <svg class="icon-svg" viewBox="0 0 24 24"><path fill="currentColor" d="M15 13V5a3 3 0 0 0-6 0v8a5 5 0 1 0 6 0m-3-9a1 1 0 0 1 1 1v3h-2V5a1 1 0 0 1 1-1Z"/></svg>
                  <span>Termistor NTC (Temperatura)</span>
                </div>
              </div>
              <!-- Mini dynamic SVG graph -->
              <div class="mini-graph">
                <svg class="sparkline" viewBox="0 0 100 30">
                  <path d="M0 25 L15 18 L30 22 L45 12 L60 15 L75 5 L90 10 L100 2" fill="none" stroke="var(--develop-accent)" stroke-width="1.5" />
                  <circle cx="75" cy="5" r="2" fill="var(--develop-accent)" />
                </svg>
                <span class="mono graph-label">LECTURA EN TIEMPO REAL (HISTORIAL)</span>
              </div>
            </div>
          </div>

          <!-- Panel 2: PINOUT & VOLTAGE -->
          <div class="dht22-panel glass" data-panel-detail="pinout">
            <div class="dht22-panel-header">
              <span class="dht22-panel-badge mono">02 / INTERFAZ</span>
              <h5>PINOUT & VOLTAGE</h5>
            </div>
            <div class="dht22-panel-body">
              <span class="tag-badge mono volt-tag">3.3V - 6V DC</span>
              <div class="pins-layout">
                <div class="pin-row"><span class="pin-num mono">1</span><strong>VCC</strong><span class="pin-desc">Alimentación (+)</span></div>
                <div class="pin-row"><span class="pin-num mono">2</span><strong>DATA</strong><span class="pin-desc">Datos serie bidireccionales</span></div>
                <div class="pin-row"><span class="pin-num mono">3</span><strong>NC</strong><span class="pin-desc">No conectado</span></div>
                <div class="pin-row"><span class="pin-num mono">4</span><strong>GND</strong><span class="pin-desc">Tierra (-)</span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Center Column: 3D Render Image with Glowing Halo -->
        <div class="dht22-center-sensor">
          <div class="dht22-glow-ring"></div>
          <img src="/dht22_sensor_render_1781719385859.png" class="dht22-render-img" alt="DHT22 Sensor Render" />
          <div class="dht22-halo-indicator"></div>
        </div>

        <!-- Right Column -->
        <div class="dht22-right-column">
          <!-- Panel 3: TECHNICAL SPECS -->
          <div class="dht22-panel glass" data-panel-detail="specs">
            <div class="dht22-panel-header">
              <span class="dht22-panel-badge mono">03 / PERFORMANCE</span>
              <h5>TECHNICAL SPECS</h5>
            </div>
            <div class="dht22-panel-body">
              <div class="spec-section">
                <div class="spec-info">
                  <strong>HUMIDITY: 0-100%</strong>
                  <span class="mono spec-accuracy">±2% precisión</span>
                </div>
                <div class="circular-dial-container">
                  <svg class="circular-dial" viewBox="0 0 36 36">
                    <path class="circular-dial-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    <path class="circular-dial-fill" stroke-dasharray="65, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                  </svg>
                  <span class="dial-value mono">65% RH</span>
                </div>
              </div>
              <div class="spec-section">
                <div class="spec-info">
                  <strong>TEMP: -40°C a 80°C</strong>
                  <span class="mono spec-accuracy">±0.5°C precisión</span>
                </div>
                <div class="thermometer-track">
                  <div class="thermometer-bar" style="width: 62%"></div>
                </div>
                <div class="temp-readout">
                  <span class="mono">24.5°C</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 4: ARDUINO CONNECTION -->
          <div class="dht22-panel glass" data-panel-detail="connection">
            <div class="dht22-panel-header">
              <span class="dht22-panel-badge mono">04 / ESQUEMA</span>
              <h5>ARDUINO CONNECTION</h5>
            </div>
            <div class="dht22-panel-body">
              <p>Conexión al microcontrolador de la base:</p>
              <div class="connection-schematic">
                <div class="schematic-item"><span class="schematic-badge mono">DHT22</span><strong>DATA (Pin 2)</strong></div>
                <div class="schematic-line-indicator"></div>
                <div class="schematic-item"><span class="schematic-badge mono nano-badge">NANO</span><strong>Pin Digital D2</strong></div>
              </div>
              <div class="resistor-notice">
                <svg class="icon-svg resistor-icon" viewBox="0 0 24 24"><path fill="currentColor" d="M22 11h-3.14l-1.5-4.5a1 1 0 0 0-1.9 0L13.86 11.8l-2-6a1 1 0 0 0-1.9 0L8.36 11H5.14A3 3 0 0 0 2.2 9H2v6h.2a3 3 0 0 0 2.94-2h3.22l1.6 4.8a1 1 0 0 0 1.9 0l2-6l1.6 4.8a1 1 0 0 0 1.9 0l1.5-4.5H22v-2Z"/></svg>
                <span>Requiere resistencia Pull-up de 10kΩ entre VCC y DATA.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab Humedad -->
    <div class="hw-tab-pane hidden" id="hw-pane-humedad">
      <div class="hw-pane-header">
        <h4>💧 Ficha: Sensor de Humedad del Suelo Capacitivo (v1.2)</h4>
      </div>
      
      <!-- Soil Moisture Interactive Infographic Container -->
      <div class="soil-infographic-container">
        <!-- Left Column -->
        <div class="soil-left-column">
          <!-- Panel 1: MEASUREMENT PRINCIPLE -->
          <div class="soil-panel glass" data-panel-detail="principle">
            <div class="soil-panel-header">
              <span class="soil-panel-badge mono">01 / MEASUREMENT PRINCIPLE</span>
              <h5>MEASUREMENT PRINCIPLE</h5>
            </div>
            <div class="soil-panel-body">
              <p>El sensor capacitivo mide la humedad utilizando cambios en la capacitancia:</p>
              <div class="principle-diagram">
                <div class="principle-item text-success">
                  <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                  <span><strong>Capacitive Field:</strong> Campo eléctrico que interactúa con la humedad del suelo sin electrodos expuestos, <strong>evitando la corrosión</strong>.</span>
                </div>
                <div class="principle-item text-danger">
                  <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span><strong>Resistive Type:</strong> Sufre <strong>corrosión galvánica rápida</strong> por el flujo directo de corriente eléctrica.</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 2: OUTPUT & CALIBRATION -->
          <div class="soil-panel glass" data-panel-detail="output">
            <div class="soil-panel-header">
              <span class="soil-panel-badge mono">02 / OUTPUT & CALIBRATION</span>
              <h5>OUTPUT & CALIBRATION</h5>
            </div>
            <div class="soil-panel-body">
              <p>Valores leídos por el microcontrolador (a menor valor, mayor humedad):</p>
              <div class="calibration-layout">
                <div class="calibration-row">
                  <span class="cal-status-icon">🏜️</span>
                  <div class="cal-details">
                    <strong>Dry (Seco): 600 - 800</strong>
                    <div class="mini-bar-track"><div class="mini-bar-fill dry" style="width: 25%"></div></div>
                  </div>
                </div>
                <div class="calibration-row">
                  <span class="cal-status-icon">🌱</span>
                  <div class="cal-details">
                    <strong>Wet (Húmedo): 200 - 400</strong>
                    <div class="mini-bar-track"><div class="mini-bar-fill wet" style="width: 85%"></div></div>
                  </div>
                </div>
                <span class="cal-notice mono">⚠️ Calibrate for soil type</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Center Column: Model Render and Soil Block -->
        <div class="soil-center-sensor">
          <div class="soil-glow-ring"></div>
          <img src="/soil_moisture_sensor_render_1781720394288.png" class="soil-render-img" alt="Capacitive Soil Moisture Sensor" />
          <div class="soil-halo-indicator"></div>
        </div>

        <!-- Right Column -->
        <div class="soil-right-column">
          <!-- Panel 3: TECHNICAL SPECS -->
          <div class="soil-panel glass" data-panel-detail="specs">
            <div class="soil-panel-header">
              <span class="soil-panel-badge mono">03 / TECHNICAL SPECS</span>
              <h5>TECHNICAL SPECS</h5>
            </div>
            <div class="soil-panel-body">
              <div class="spec-section">
                <div class="spec-info">
                  <strong>OPERATING VOLTAGE</strong>
                  <span class="spec-accuracy">3.3V - 5.5V DC</span>
                </div>
              </div>
              <div class="spec-section">
                <div class="spec-info">
                  <strong>OUTPUT</strong>
                  <span class="spec-accuracy">Analog Voltage (0 - VCC)</span>
                </div>
              </div>
              <div class="spec-section" style="border-bottom: none; padding-bottom: 0;">
                <div class="spec-info" style="margin-bottom: 0.25rem;">
                  <strong>DURABILIDAD</strong>
                </div>
                <div class="circular-dial-container">
                  <div class="circular-dial">
                    <svg viewBox="0 0 36 36">
                      <path class="circular-dial-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                      <path class="circular-dial-fill" stroke-dasharray="100, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    </svg>
                  </div>
                  <div class="dial-value-container">
                    <span class="dial-value">100%</span>
                    <span class="graph-label" style="display: block; font-size: 0.65rem; color: var(--soil-accent); font-weight: 500;">Stable & Corrosion-Resistant</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 4: PINOUT & CONNECTION -->
          <div class="soil-panel glass" data-panel-detail="connection">
            <div class="soil-panel-header">
              <span class="soil-panel-badge mono">04 / PINOUT & CONNECTION</span>
              <h5>PINOUT & ARDUINO CONNECTION</h5>
            </div>
            <div class="soil-panel-body">
              <div class="pins-layout">
                <div class="pin-row">
                  <span class="pin-num">1</span>
                  <strong>VCC</strong>
                  <span class="pin-desc">Alimentación 3.3V / 5V</span>
                </div>
                <div class="pin-row">
                  <span class="pin-num">2</span>
                  <strong>GND</strong>
                  <span class="pin-desc">Toma de Tierra Común</span>
                </div>
                <div class="pin-row">
                  <span class="pin-num">3</span>
                  <strong>AOUT</strong>
                  <span class="pin-desc">Señal Analógica</span>
                </div>
              </div>

              <div class="connection-schematic" style="margin-top: 0.5rem;">
                <div class="schematic-item">
                  <span class="schematic-badge mono">SENSOR</span>
                  <strong>AOUT (Pin 3)</strong>
                </div>
                <div class="schematic-line-indicator"></div>
                <div class="schematic-item" style="align-items: flex-end;">
                  <span class="schematic-badge nano-badge mono">NANO</span>
                  <strong>Analog Pin A0</strong>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab LDR -->
    <div class="hw-tab-pane hidden" id="hw-pane-ldr">
      <div class="hw-pane-header">
        <h4>☀️ Ficha: Sensor de Luz (LDR)</h4>
      </div>
      
      <!-- LDR Interactive Infographic Container -->
      <div class="ldr-infographic-container">
        <!-- Left Column -->
        <div class="ldr-left-column">
          <!-- Panel 1: MEASUREMENT PRINCIPLE -->
          <div class="ldr-panel glass" data-panel-detail="principle">
            <div class="ldr-panel-header">
              <span class="ldr-panel-badge mono">01 / DETECTOR</span>
              <h5>PRINCIPIO DE DETECCIÓN</h5>
            </div>
            <div class="ldr-panel-body">
              <p>La resistencia eléctrica del fotorresistor LDR disminuye drásticamente a medida que recibe más fotones (luz):</p>
              <div class="mini-graph">
                <svg class="sparkline" viewBox="0 0 100 30" style="overflow: visible;">
                  <!-- Curva inversa: Luz alta -> Resistencia baja -->
                  <path d="M5 25 Q30 22 45 12 T95 5" fill="none" stroke="var(--ldr-accent)" stroke-width="1.5" />
                  <circle cx="5" cy="25" r="2.5" fill="#ef4444" />
                  <circle cx="95" cy="5" r="2.5" fill="var(--ldr-accent)" />
                </svg>
                <div style="display: flex; justify-content: space-between; font-size: 0.6rem; color: hsl(var(--text-muted)); margin-top: 0.2rem;">
                  <span>Oscuridad (Máx. Resistencia)</span>
                  <span>Luz Alta (Mín. Resistencia)</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 2: COMPARATOR & POTENTIOMETER -->
          <div class="ldr-panel glass" data-panel-detail="comparator">
            <div class="ldr-panel-header">
              <span class="ldr-panel-badge mono">02 / COMPARADOR</span>
              <h5>DOBLE SALIDA & UMBRAL</h5>
            </div>
            <div class="ldr-panel-body">
              <p>El comparador LM393 y el potenciómetro azul permiten ajustar el umbral de disparo:</p>
              <div class="pins-layout">
                <div class="pin-row">
                  <span class="pin-num mono">A</span>
                  <strong>Salida Analógica (AO):</strong>
                  <span class="pin-desc">Lectura directa de 0 a 1023.</span>
                </div>
                <div class="pin-row">
                  <span class="pin-num mono">D</span>
                  <strong>Salida Digital (DO):</strong>
                  <span class="pin-desc">Señal TTL 0/1 basada en el umbral.</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Center Column: Model Render with Halo -->
        <div class="ldr-center-sensor">
          <div class="ldr-glow-ring"></div>
          <img src="/ldr_sensor_render.png" class="ldr-render-img" alt="LDR Light Sensor Render" />
          <div class="ldr-halo-indicator"></div>
        </div>

        <!-- Right Column -->
        <div class="ldr-right-column">
          <!-- Panel 3: TECHNICAL SPECS -->
          <div class="ldr-panel glass" data-panel-detail="specs">
            <div class="ldr-panel-header">
              <span class="ldr-panel-badge mono">03 / PERFORMANCE</span>
              <h5>ESPECIFICACIONES TÉCNICAS</h5>
            </div>
            <div class="ldr-panel-body">
              <div class="spec-section">
                <div class="spec-info">
                  <strong>VOLTAJE DE TRABAJO</strong>
                  <span class="spec-accuracy">3.3V - 5V DC</span>
                </div>
              </div>
              <div class="spec-section">
                <div class="spec-info">
                  <strong>SALIDAS</strong>
                  <span class="spec-accuracy">Analógica y Digital (TTL)</span>
                </div>
              </div>
              <div class="spec-section" style="border-bottom: none; padding-bottom: 0;">
                <div class="spec-info">
                  <strong>SENSIBILIDAD</strong>
                </div>
                <div class="circular-dial-container">
                  <svg class="circular-dial" viewBox="0 0 36 36">
                    <path class="circular-dial-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    <path class="circular-dial-fill" stroke-dasharray="75, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                  </svg>
                  <span class="dial-value mono" style="font-size: 0.75rem; color: var(--ldr-accent);">Ajustable por Potenciómetro</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 4: ARDUINO CONNECTION -->
          <div class="ldr-panel glass" data-panel-detail="connection">
            <div class="ldr-panel-header">
              <span class="ldr-panel-badge mono">04 / CONEXIONADO</span>
              <h5>PINOUT & CONEXIÓN</h5>
            </div>
            <div class="ldr-panel-body">
              <p>Conexión del módulo LDR al microcontrolador:</p>
              <div class="pins-layout" style="margin-bottom: 0.5rem;">
                <div class="pin-row"><span class="pin-num mono">1</span><strong>VCC</strong><span class="pin-desc">A 5V / 3.3V</span></div>
                <div class="pin-row"><span class="pin-num mono">2</span><strong>GND</strong><span class="pin-desc">A GND Común</span></div>
                <div class="pin-row"><span class="pin-num mono">3</span><strong>DO</strong><span class="pin-desc">Digital Out (a Pin D3)</span></div>
                <div class="pin-row"><span class="pin-num mono">4</span><strong>AO</strong><span class="pin-desc">Analog Out (a Pin A1)</span></div>
              </div>
              <div class="connection-schematic">
                <div class="schematic-item"><span class="schematic-badge mono">LDR</span><strong>AO (Pin 4)</strong></div>
                <div class="schematic-line-indicator"></div>
                <div class="schematic-item"><span class="schematic-badge mono nano-badge">NANO</span><strong>Analog Pin A1</strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab Bomba -->
    <div class="hw-tab-pane hidden" id="hw-pane-bomba">
      <div class="hw-pane-header">
        <h4>⚙️ Ficha: Minibomba de Agua & Relé Mecánico</h4>
      </div>

      <!-- Pump & Relay Interactive Infographic Container -->
      <div class="pump-infographic-container">
        <!-- Left Column -->
        <div class="pump-left-column">
          <!-- Panel 1: PUMP MECHANISM -->
          <div class="pump-panel glass" data-panel-detail="mechanism">
            <div class="pump-panel-header">
              <span class="pump-panel-badge mono">01 / MECÁNICA</span>
              <h5>MECANISMO DE RIEGO</h5>
            </div>
            <div class="pump-panel-body">
              <p><strong>Desplazamiento Positivo:</strong> Los rodillos comprimen el tubo peristáltico de forma secuencial, empujando el agua hacia el biodomo y previniendo el reflujo de fluidos.</p>
              <div class="mini-graph" style="border-top: none; padding-top: 0; display: flex; align-items: center; justify-content: center; margin-top: 0;">
                <!-- Simple pump roller indicator SVG -->
                <svg viewBox="0 0 100 40" style="width: 100px; height: 40px; fill: none; stroke: var(--pump-accent); stroke-width: 1.5;">
                  <circle cx="50" cy="20" r="15" stroke-dasharray="4, 4" />
                  <circle cx="50" cy="20" r="5" fill="var(--pump-accent)" />
                  <line x1="50" y1="20" x2="50" y2="5" />
                  <line x1="50" y1="20" x2="37" y2="28" />
                  <line x1="50" y1="20" x2="63" y2="28" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Panel 2: RELAY SWITCHING -->
          <div class="pump-panel glass" data-panel-detail="relay">
            <div class="pump-panel-header">
              <span class="pump-panel-badge mono">02 / AISLAMIENTO</span>
              <h5>CONMUTACIÓN POR RELÉ</h5>
            </div>
            <div class="pump-panel-body">
