---
import './HubCard.css';

interface DotTag {
  text: string;
  colorClass: string;
}

interface Props {
  title: string;
  description: string;
  index: string;
  href: string;
  actionText?: string;
  tags?: string[];
  disabled?: boolean;
  dotTag?: DotTag;
}

const { title, description, index, href, actionText, tags = [], disabled = false, dotTag } = Astro.props;
---

<div class={`hub-card ${disabled ? 'card-disabled' : ''}`}>
  <div class="hub-card-header">
    {dotTag ? (
      <span class="dot-tag mono">
        <span class={`dot ${dotTag.colorClass}`}></span>
        {dotTag.text}
      </span>
    ) : (
      <span></span>
    )}
    <span class="index-badge mono">[{index}]</span>
  </div>
  <div class="hub-card-body">
    <h3 class="hub-card-title">{title}</h3>
    <p class="hub-card-description">{description}</p>
  </div>
  <div class="hub-card-footer">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => (
          <span class="card-tag mono">{tag}</span>
        ))}
      </div>
    )}
    
    {disabled ? (
      <span class="card-link-disabled mono">[BLOQUEADO]</span>
    ) : (
      actionText && (
        <a href={href} class="card-link mono">
          {actionText}
        </a>
      )
    )}
  </div>
</div>

<script src="./HubCard.js"></script>
